        "richTextValue" : "<div style=\"max-width:1000px; margin:auto;\">\n\n<!-- Heading Section -->\n    <div style=\"padding:0 0 10px 10px;\">\n        <h2 style=\"margin:0;\">Health Inspection Reports</h2>\n <!-- Yellow line -->\n    <div style=\"width:25px; height:4px; background-color:#FFC107; margin:6px 0 10px 0;\"></div>        <br/>\n        <p style=\"margin:0; color:#666;\">Select a program area to start searching for facilities in B.C.</p>\n    </div>\n    <br/>\n\t<br/>\n <!-- Button Grid -->\n<div class=\"slds-grid slds-wrap\">\n\n<div class=\"slds-size_1-of-1 slds-medium-size_1-of-3 slds-p-around_small\">\n\n<a href=\"/phocsservices/s/facility-list?PA=food\" class=\"slds-button slds-button_brand  custom-btn\"  style=\"width:250px;background-color:white;color:#003366;width:100%\"><b>Food</b></a>\n\n</div>\n\n<div class=\"slds-size_1-of-1 slds-medium-size_1-of-3 slds-p-around_small\">\n\n<a href=\"/phocsservices/s/facility-list?PA=childcare\" class=\"slds-button slds-button_brand  custom-btn\" style=\"width:250px;background-color:white;color:#003366;width:100%\"><b>Child Care</b></a>\n\n</div>\n\n<div class=\"slds-size_1-of-1 slds-medium-size_1-of-3 slds-p-around_small\">\n\n<a href=\"/phocsservices/s/facility-list?PA=residentialcare\" class=\"slds-button slds-button_brand  custom-btn\" style=\"width:250px;background-color:white;color:#003366;width:100%\"><b>Residential Care</b></a>\n\n</div>\n\n\n\n<div class=\"slds-size_1-of-1 slds-medium-size_1-of-3 slds-p-around_small\">\n\n<a href=\"/phocsservices/s/facility-list?PA=personalservices\" class=\"slds-button slds-button_neutral  custom-btn\" style=\"width:250px;background-color:white;color:#003366;width:100%\"><b>Personal Services</b></a>\n\n</div>\n\n<div class=\"slds-size_1-of-1 slds-medium-size_1-of-3 slds-p-around_small\">\n\n<a href=\"/phocsservices/s/facility-list?PA=childcareowl\" class=\"slds-button slds-button_neutral  custom-btn\" style=\"width:250px;background-color:white;color:#003366;width:100%\"><b>Child Care (OWL)</b></a>\n\n</div>\n\n<div class=\"slds-size_1-of-1 slds-medium-size_1-of-3 slds-p-around_small\">\n\n<a href=\"/phocsservices/s/facility-list?PA=residentialcareowl\" class=\"slds-button slds-button_neutral  custom-btn\" style=\"width:250px;background-color:white;color:#003366;width:100%\"><b>Residential Care (OWL)</b></a>\n\n</div>\n\n\n\n<div class=\"slds-size_1-of-1 slds-medium-size_1-of-3 slds-p-around_small\">\n\n<a href=\"/phocsservices/s/facility-list?PA=tobaccoandvapour\" class=\"slds-button slds-button_outline-brand  custom-btn\" style=\"width:250px;background-color:white;color:#003366;width:100%\"><b>Tobacco and Vapour</b></a>\n\n</div>\n\n<div class=\"slds-size_1-of-1 slds-medium-size_1-of-3 slds-p-around_small\">\n\n<a href=\"/phocsservices/s/facility-list?PA=recreationalwater\" class=\"slds-button slds-button_outline-brand  custom-btn\" style=\"width:250px;background-color:white;color:#003366;width:100%\"><b>Recreational Water</b></a>\n\n</div>\n\n<div class=\"slds-size_1-of-1 slds-medium-size_1-of-3 slds-p-around_small\">\n\n<a href=\"/phocsservices/s/facility-list?PA=drinkingwatersystem\" class=\"slds-button slds-button_outline-brand  custom-btn\" style=\"width:250px;background-color:white;color:#003366;width:100%\"><b>Drinking Water</b></a>\n\n</div>\n\n    </div>\n <div style=\"text-align:left; margin-top:15px; padding-left:10px; color:#666; font-size:12px;\">\n       <b>Note</b> (OWL) indicates facilities operating without a license\n    </div><br/><br/>\n\n</div>"
