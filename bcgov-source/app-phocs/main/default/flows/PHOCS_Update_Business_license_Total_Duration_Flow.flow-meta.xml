            </connector>
            <label>Total duration field</label>
        </rules>
        <rules>
            <name>period_end_field_changed</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record.PeriodEnd</leftValueReference>
                <operator>IsChanged</operator>
                <rightValue>
                    <booleanValue>true</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.PeriodEnd</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDateTime</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_the_recordtype_of_contact</targetReference>
            </connector>
            <label>period end field changed</label>
        </rules>
        <rules>
            <name>period_end_date_is_updated_to_past_date</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>$Record__Prior.PeriodEnd</leftValueReference>
                <operator>GreaterThan</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDateTime</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.PeriodEnd</leftValueReference>
                <operator>LessThanOrEqualTo</operator>
                <rightValue>
                    <elementReference>$Flow.CurrentDateTime</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_the_recordtype_of_contact_bl</targetReference>
            </connector>
            <label>period end date is updated to past date</label>
        </rules>
    </decisions>
    <description>This flow is used to update the Total restricted license duration field on contact with the Business license estricted license duration (Months) field</description>
    <environments>Default</environments>
    <formulas>
        <name>AddDurationBL</name>
        <dataType>Number</dataType>
        <expression>{!Get_all_bl_duration_count.RestrictedLicenceDuration__c} + {!get_contact.PHOCSTotalrestrictedlicenseduration__c}</expression>
        <scale>2</scale>
    </formulas>
    <formulas>
        <name>NewValue</name>
        <dataType>Number</dataType>
        <expression>IF(ISBLANK({!get_contact.PHOCSTotallicenseyears__c}),0,IF({!get_contact.PHOCSTotallicenseyears__c} &lt;= 1,0,{!get_contact.PHOCSTotallicenseyears__c} - 1))</expression>
        <scale>2</scale>
    </formulas>
    <interviewLabel>PHOCS Update Business license {!$Flow.CurrentDateTime}</interviewLabel>
    <label>PHOCS Update Business license Total Duration Flow</label>
    <loops>
