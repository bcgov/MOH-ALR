    <formulas>
        <name>DocumentchecklistName</name>
        <dataType>String</dataType>
        <expression>TRIM(
  RIGHT(
    {!$Record.Name},
    LEN( {!$Record.Name}) - FIND(&quot;. &quot;,  {!$Record.Name})
  )
)</expression>
