        <rules>
            <name>Name_contains_ERCP</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>$Record.Name</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <elementReference>ERCP</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>Contains</operator>
                <rightValue>
                    <elementReference>ERCP</elementReference>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Document_Checklist_Items_ERCP</targetReference>
            </connector>
            <label>Name or Record Type Name contains ERCP</label>
        </rules>
        <rules>
            <name>IS_Retrieved_From_Custom_Metadata</name>
            <conditionLogic>or</conditionLogic>
            <conditions>
                <leftValueReference>RecordTypefromCustommetadata.RecordTypeName__c</leftValueReference>
                <operator>IsBlank</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>$Record.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>PHOCSDrawingPlanDocumentChecklist</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Update_Records_DrawingPlan</targetReference>
            </connector>
            <label>IS Retrieved From Custom Metadata</label>
        </rules>
    </decisions>
    <description>EHIS-905: Update DocumentChecklistItems record types based on PHOCS Business License Application record types</description>
