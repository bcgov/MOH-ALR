    <decisions>
        <name>Check_BLA_Record_Type</name>
        <label>Check BLA Record Type</label>
        <locationX>578</locationX>
        <locationY>827</locationY>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>PHOCS_BLA_Record_Types</name>
            <conditionLogic>(1 OR 2 OR 3 OR 5) AND 4</conditionLogic>
            <conditions>
                <leftValueReference>Get_BLA.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>BLAConstructionPermitApplication</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_BLA.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>BLAOperatingPermitApplication</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_BLA.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <elementReference>BLAEvaluation</elementReference>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_BLA</leftValueReference>
                <operator>IsNull</operator>
                <rightValue>
                    <booleanValue>false</booleanValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_BLA.RecordType.DeveloperName</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>PHOCSExemptions</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Check_Document_Checklist_Item</targetReference>
            </connector>
            <label>PHOCS BLA Record Types</label>
        </rules>
    </decisions>
