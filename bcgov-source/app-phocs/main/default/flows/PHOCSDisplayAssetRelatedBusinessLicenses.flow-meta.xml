                <rightValue>
                    <stringValue>Pool Construction Permit</stringValue>
                </rightValue>
            </conditions>
            <conditions>
                <leftValueReference>Get_BL.RegulatoryAuthorizationType.Name</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <stringValue>Pool Operating Permit</stringValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Assign_BLs</targetReference>
            </connector>
            <label>Eligible</label>
        </rules>
    </decisions>
