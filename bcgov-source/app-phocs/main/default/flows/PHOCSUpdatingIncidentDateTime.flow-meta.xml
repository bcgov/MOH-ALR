<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <areMetricsLoggedToDataCloud>false</areMetricsLoggedToDataCloud>
    <assignments>
        <name>Set_IncidentDate</name>
        <label>Set IncidentDate</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <assignmentItems>
            <assignToReference>$Record.IncidentDate</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>$Record.ReceivedDate</elementReference>
            </value>
        </assignmentItems>
    </assignments>
    <description>Set System-required field IncidentDate value as ReceivedDate to avoid creation error on PHOCS specific record type on PublicComplaint object</description>
    <environments>Default</environments>
    <interviewLabel>PHOCS Updating Incident Date/Time {!$Flow.CurrentDateTime}</interviewLabel>
    <label>PHOCS Updating Incident Date/Time</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Set_IncidentDate</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>PHOCSRecordtype__c</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>PHOCSPublicRequestInquiry</stringValue>
            </value>
        </filters>
        <filters>
            <field>IncidentDate</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>PublicComplaint</object>
        <recordTriggerType>Create</recordTriggerType>
        <triggerType>RecordBeforeSave</triggerType>
    </start>
    <status>Active</status>
</Flow>
