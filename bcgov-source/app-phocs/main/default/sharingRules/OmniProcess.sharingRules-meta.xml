<?xml version="1.0" encoding="UTF-8"?>
<SharingRules xmlns="http://soap.sforce.com/2006/04/metadata">
    <sharingCriteriaRules>
        <fullName>Share_PHOCS_Omni_Process_with_Operators</fullName>
        <accessLevel>Read</accessLevel>
        <description>OmniScript</description>
        <label>Share PHOCS Omni Process with Operators</label>
        <sharedTo>
            <group>PHOCSOperatorUserPG</group>
        </sharedTo>
        <criteriaItems>
            <field>Name</field>
            <operation>contains</operation>
            <value>PHOCS</value>
        </criteriaItems>
        <includeRecordsOwnedByAll>true</includeRecordsOwnedByAll>
    </sharingCriteriaRules>
    <sharingGuestRules>
        <fullName>PHOCS_Share_OmniProcess_ForGU</fullName>
        <accessLevel>Read</accessLevel>
        <description>Share OS for PHOCS Guest Site Users</description>
        <label>PHOCS_Share_OmniProcess_ForGU</label>
        <sharedTo>
            <guestUser>phocsservices</guestUser>
        </sharedTo>
        <criteriaItems>
            <field>Name</field>
            <operation>contains</operation>
            <value>PHOCS</value>
        </criteriaItems>
        <includeHVUOwnedRecords>false</includeHVUOwnedRecords>
    </sharingGuestRules>
</SharingRules>
