<?xml version="1.0" encoding="UTF-8"?>
<SharingRules xmlns="http://soap.sforce.com/2006/04/metadata">
    <sharingCriteriaRules>
        <fullName>OmniUICard_Portal_User_Rule</fullName>
        <accessLevel>Read</accessLevel>
        <label>OmniUICard Portal User Rule</label>
        <sharedTo>
            <group>PHOCSOperatorUserPG</group>
        </sharedTo>
        <criteriaItems>
            <field>Name</field>
            <operation>contains</operation>
            <value>PHOCS</value>
        </criteriaItems>
        <includeRecordsOwnedByAll>true</includeRecordsOwnedByAll>
    </sharingCriteriaRules>
    <sharingGuestRules>
        <fullName>OmniUICard_Guest_User_Rule</fullName>
        <accessLevel>Read</accessLevel>
        <label>OmniUICard Guest User Rule</label>
        <sharedTo>
            <guestUser>phocsservices</guestUser>
        </sharedTo>
        <criteriaItems>
            <field>UniqueName</field>
            <operation>contains</operation>
            <value>PHOCS</value>
        </criteriaItems>
        <includeHVUOwnedRecords>false</includeHVUOwnedRecords>
    </sharingGuestRules>
</SharingRules>
