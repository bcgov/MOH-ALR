<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>ValidateRecommendedActionStatusDate</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
 NOT(ISBLANK(TEXT(RecommendedActionStatus__c))),
 ISBLANK(TEXT(RecommendedActionStatusDate__c)) 
)</errorConditionFormula>
    <errorDisplayField>RecommendedActionStatusDate__c</errorDisplayField>
    <errorMessage>Recommended Action Status Date is Required</errorMessage>
</ValidationRule>
